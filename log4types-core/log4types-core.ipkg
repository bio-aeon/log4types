package log4types-core
version = 0.1.0
authors = "Alexandr Chigrinets"
license = "MIT"
brief   = "Core algebra for composable logging, refined by dependent types"

depends = base
        , contrib

sourcedir = "src"

modules = Log4Types.Core
        , Log4Types.Core.Action
        , Log4Types.Core.Loggable
        , Log4Types.Core.TestLog
        , Log4Types.Core.Renderer
        , Log4Types.Core.Severity
        , Log4Types.Core.Value
