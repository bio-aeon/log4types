package log4types
version = 0.2.0
authors = "Alexandr Chigrinets"
license = "MIT"
brief   = "Composable structured logging for Idris 2 applications"

depends = base
        , contrib
        , log4types-core

sourcedir = "src"

modules = Log4Types
        , Log4Types.ANSI
        , Log4Types.Context
        , Log4Types.File
        , Log4Types.Format
        , Log4Types.HasLog
        , Log4Types.IO
        , Log4Types.Message
